FROM maven:3.9-eclipse-temurin-21

RUN apt-get update \
    && apt-get install -y --no-install-recommends inotify-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY docker/dev-entrypoint.sh /usr/local/bin/bezzer-dev
RUN chmod +x /usr/local/bin/bezzer-dev

EXPOSE 8080
ENTRYPOINT ["bezzer-dev"]
